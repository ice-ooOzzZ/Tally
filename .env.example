# 复制为 .env 并填入真实值；.env 已加入 .gitignore，不入库。
# config/*.yaml 中以 `env:VAR` 语义引用这些变量（见 IMPLEMENTATION_SPEC.md §0/§10）。

# Tushare Pro API token（A股行情/财务/估值主源）
TUSHARE_TOKEN=your_tushare_token_here

# Telegram Bot（日报/告警推送，v2.2.1 起通知渠道由 Slack 改为 Telegram）
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# 注意：SEC EDGAR 的 User-Agent 不走 .env / env:VAR ——它不是密钥（SEC 本就要求
# 公开可核实的联系方式），直接硬编码在 config/system.yaml 的 sec_user_agent 里，
# 因此本文件不再列出 SEC_USER_AGENT，避免让人误以为它是从环境变量解析的。
